# ==============================================
# Aferent monorepo environment template
# Copy this file to .env and fill your real values.
# ==============================================

# ---------- Shared security ----------
JWT_SECRET=replace-with-long-random-secret

# ---------- MongoDB (per service DB) ----------
MONGO_URI_AUTH_SERVICE=mongodb+srv://<user>:<password>@<cluster>/auth_db?retryWrites=true&w=majority
MONGO_URI_PATIENT_SERVICE=mongodb+srv://<user>:<password>@<cluster>/patient_db?retryWrites=true&w=majority
MONGO_URI_DOCTOR_SERVICE=mongodb+srv://<user>:<password>@<cluster>/doctor_db?retryWrites=true&w=majority
MONGO_URI_APPOINTMENT_SERVICE=mongodb+srv://<user>:<password>@<cluster>/appointment_db?retryWrites=true&w=majority
MONGO_URI_NOTIFICATION_SERVICE=mongodb+srv://<user>:<password>@<cluster>/notification_db?retryWrites=true&w=majority
MONGO_URI_PAYMENT_SERVICE=mongodb+srv://<user>:<password>@<cluster>/payment_db?retryWrites=true&w=majority
MONGO_URI_SYMPTOM_SERVICE=mongodb+srv://<user>:<password>@<cluster>/symptom_db?retryWrites=true&w=majority

# ---------- MinIO / Document storage ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGION=us-east-1
MINIO_BUCKET=app-storage
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ---------- Telemedicine (Agora) ----------
AGORA_APP_ID=replace-with-agora-app-id
AGORA_APP_CERTIFICATE=replace-with-agora-app-certificate
AGORA_WEBHOOK_SECRET=replace-with-agora-webhook-secret
AGORA_TOKEN_TTL_SEC=3600

# ---------- Notification service ----------
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000

GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=replace-with-google-app-password
GMAIL_FROM_NAME=Aferent Notifications

# ---------- Payment service ----------
STRIPE_SECRET_KEY=replace-with-stripe-secret-key

# ---------- Symptom detector (Gemini) ----------
GEMINI_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30

# ---------- Optional / overrides ----------
# Used by doctor-service in compose if provided
DOCTOR_LOGIN_URL=http://localhost:3000/login
